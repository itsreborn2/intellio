{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "backend:dev": "cross-env PYTHONPATH=.. .venv/Scripts/python main.py",
    "setup": "python -m venv .venv && cross-env PIP_USER=0 .venv/Scripts/python -m pip install -r requirements.txt",
    "install": "cross-env PIP_USER=0 .venv/Scripts/python -m pip install -r requirements.txt"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
